⚠️ NAMING RULES (NON-NEGOTIABLE)

❌ No camelCase → use dot notation

❌ No random names (primaryColor, blue1)

❌ No component tokens at global level

✅ Always hierarchical

✅ Always predictable

🔌 2. MAPPING LAYER (CRITICAL)

This is what connects EVERYTHING.

🧠 Concept

Each token must map to:

Token → Figma → CSS → Tailwind → Component
🎯 2.1 MASTER MAPPING OBJECT
{
  "button.primary.bg": {
    "token": "color.brand.primary",
    "figma": {
      "property": "fill"
    },
    "css": {
      "property": "background-color",
      "variable": "--color-brand-primary"
    },
    "tailwind": "bg-brand-primary",
    "component": "Button.Primary"
  }
}
🎨 2.2 COLOR MAPPING
{
  "color.bg.primary": {
    "figma": "fill",
    "css": "background-color",
    "tailwind": "bg-primary"
  },
  "color.text.primary": {
    "figma": "text",
    "css": "color",
    "tailwind": "text-primary"
  }
}
📏 2.3 SPACING MAPPING
{
  "spacing.4": {
    "figma": "padding/gap",
    "css": "padding",
    "tailwind": "p-4"
  }
}
🔲 2.4 RADIUS
{
  "radius.md": {
    "figma": "cornerRadius",
    "css": "border-radius",
    "tailwind": "rounded-md"
  }
}
🔤 2.5 TYPOGRAPHY
{
  "text.body.md": {
    "figma": "textStyle",
    "css": ["font-size", "line-height", "font-weight"],
    "tailwind": "text-base"
  }
}
🌫 2.6 SHADOW
{
  "shadow.sm": {
    "figma": "effects",
    "css": "box-shadow",
    "tailwind": "shadow-sm"
  }
}
🧱 2.7 BORDER
{
  "border.default": {
    "figma": "stroke",
    "css": "border",
    "tailwind": "border"
  }
}
🔳 2.8 OPACITY
{
  "opacity.disabled": {
    "figma": "opacity",
    "css": "opacity",
    "tailwind": "opacity-40"
  }
}
🎞 2.9 MOTION
{
  "motion.duration.fast": {
    "css": "transition-duration",
    "tailwind": "duration-150"
  }
}
🧱 2.10 Z-INDEX
{
  "z.modal": {
    "css": "z-index",
    "tailwind": "z-50"
  }
}
